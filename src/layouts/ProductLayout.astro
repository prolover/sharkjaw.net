---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SpecTable from '../components/SpecTable.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CertLogos from '../components/CertLogos.astro';
import CTABlock from '../components/CTABlock.astro';
import ProductCard from '../components/ProductCard.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { getCollection } from 'astro:content';

interface Download {
  label: string;
  file: string | null;
  gated?: boolean;
}

interface Spec {
  model: string;
  holdingCapacity?: number;
  bollardPull?: number;
  chainDiaRange?: string;
  jawOpening?: string;
  dimensions?: string;
  weight?: string;
  hydraulicPressure?: string;
  power?: number;
}

interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    heroImage?: string;
    gallery?: string[];
    specs?: Spec[];
    faq?: FAQItem[];
    certifications?: string[];
    swlRange?: string;
    types?: string[];
    relatedProducts?: string[];
    downloads?: Download[];
    lastUpdated?: Date;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;

const {
  title,
  description,
  heroImage,
  gallery = [],
  specs = [],
  faq = [],
  certifications = [],
  swlRange,
  types = [],
  relatedProducts = [],
  downloads = [],
  lastUpdated,
} = frontmatter;

// Resolve related product entries
const allProducts = relatedProducts.length > 0
  ? await getCollection('products')
  : [];
const relatedEntries = allProducts.filter(p => relatedProducts.includes(p.slug));

// Breadcrumb items
const breadcrumbItems = [
  { label: 'Products', href: '/products/' },
  { label: title },
];

// Last updated formatted
const lastUpdatedFormatted = lastUpdated
  ? new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }).format(lastUpdated)
  : null;
---

<BaseLayout title={title} description={description} image={heroImage} type="Product">
  <!-- Extra Schema: Product + FAQPage (augments BaseLayout's SchemaOrg) -->
  <SchemaOrg
    type="Product"
    title={title}
    description={description}
    image={heroImage ? new URL(heroImage, Astro.site).href : undefined}
    faq={faq.length ? faq : undefined}
    product={{
      name: title,
      description,
      image: heroImage ? [new URL(heroImage, Astro.site).href] : undefined,
      swlRange,
      certifications,
    }}
  />

  <div class="product-page">
    <!-- Breadcrumb -->
    <div class="container">
      <Breadcrumb items={breadcrumbItems} />
    </div>

    <!-- Hero Section -->
    <section class="product-hero section-dark">
      <div class="container product-hero-inner">
        <div class="product-hero-text">
          <h1 class="product-hero-title">{title}</h1>
          <p class="product-hero-desc">{description}</p>

          <div class="product-hero-meta">
            {swlRange && (
              <div class="meta-badge meta-badge-swl">
                <span class="meta-label">SWL Range</span>
                <span class="meta-value">{swlRange}</span>
              </div>
            )}
          </div>

          {types.length > 0 && (
            <div class="product-type-pills">
              <span class="pills-label">Available Types:</span>
              <div class="pills">
                {types.map(t => <span class="pill">{t}</span>)}
              </div>
            </div>
          )}

          {certifications.length > 0 && (
            <div class="product-cert-pills">
              <span class="pills-label">Classification:</span>
              <div class="pills">
                {certifications.map(c => <span class="pill pill-cert">{c}</span>)}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Two-Column: Image Gallery + Quick Specs / CTA -->
    <section class="product-overview section">
      <div class="container product-overview-grid">

        <!-- Left: Image Gallery -->
        <div class="product-gallery">
          {heroImage ? (
            <div class="gallery-main" id="gallery-main">
              <img src={heroImage} alt={title} class="gallery-img" id="gallery-main-img" />
            </div>
          ) : (
            <div class="gallery-placeholder">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="9" cy="9" r="2"/>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
              </svg>
              <p>Product images available on request</p>
            </div>
          )}
          {gallery.length > 1 ? (
            <div class="gallery-thumbs">
              {gallery.map((img, i) => (
                <button
                  class={`gallery-thumb-btn ${i === 0 ? 'active' : ''}`}
                  data-src={img}
                  aria-label={`View image ${i + 1}`}
                >
                  <img src={img} alt={`${title} — view ${i + 1}`} class="gallery-thumb-img" loading="lazy" />
                </button>
              ))}
            </div>
          ) : gallery.length === 0 && !heroImage ? null : (
            <div class="gallery-thumbs gallery-thumbs-placeholder">
              {[1, 2, 3].map(() => (
                <div class="gallery-thumb"></div>
              ))}
            </div>
          )}
        </div>

        <!-- Right: Quick Specs + CTA -->
        <div class="product-sidebar">
          {specs.length > 0 && (
            <div class="quick-specs card">
              <h3 class="quick-specs-title">Quick Reference</h3>
              <dl class="quick-specs-list">
                {swlRange && (
                  <>
                    <dt>SWL Range</dt>
                    <dd>{swlRange}</dd>
                  </>
                )}
                {specs[0]?.hydraulicPressure && (
                  <>
                    <dt>Hydraulic Pressure</dt>
                    <dd>{specs[0].hydraulicPressure}</dd>
                  </>
                )}
                {specs[0]?.chainDiaRange && (
                  <>
                    <dt>Chain Dia. Range</dt>
                    <dd>{specs[0].chainDiaRange}</dd>
                  </>
                )}
                {specs[0]?.jawOpening && (
                  <>
                    <dt>Jaw Opening</dt>
                    <dd>{specs[0].jawOpening}</dd>
                  </>
                )}
                {certifications.length > 0 && (
                  <>
                    <dt>Classification</dt>
                    <dd>{certifications.join(', ')}</dd>
                  </>
                )}
                <dt>Lead Time</dt>
                <dd>8–12 weeks</dd>
                <dt>Incoterms</dt>
                <dd>FOB / CIF / CFR</dd>
              </dl>
            </div>
          )}

          <div class="sidebar-cta card card-accent">
            <h3>Get a Quote for This Product</h3>
            <p>Tell us your vessel type, required SWL, and classification society.</p>
            <a href="/contact/" class="btn btn-primary sidebar-cta-btn">
              Request a Quote
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="/contact/" class="btn btn-ghost sidebar-cta-btn-secondary">
              Ask a Technical Question
            </a>
          </div>

          {lastUpdatedFormatted && (
            <p class="last-updated">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Last updated: {lastUpdatedFormatted}
            </p>
          )}
        </div>
      </div>
    </section>

    <!-- MDX Body Content (prose sections, custom components, etc.) -->
    {Astro.slots.has('default') && (
      <section class="product-body section">
        <div class="container container-narrow prose">
          <slot />
        </div>
      </section>
    )}

    <!-- Full Spec Table -->
    {specs.length > 0 && (
      <section class="product-specs section" id="specifications">
        <div class="container">
          <h2 class="section-title">Technical Specifications</h2>
          <SpecTable specs={specs} caption={`${title} technical specifications`} />
          <p class="spec-note">
            All specifications subject to final engineering review. Custom SWL configurations available on request.
          </p>
        </div>
      </section>
    )}

    <!-- Types Section -->
    {types.length > 0 && (
      <section class="product-types section" id="types">
        <div class="container">
          <h2 class="section-title">Available Types</h2>
          <div class="types-grid">
            {types.map(type => (
              <div class="type-card card">
                <div class="type-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3 class="type-name">{type}</h3>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Certifications -->
    <section class="product-certifications section section-light" id="certifications">
      <div class="container">
        <h2 class="section-title">Classification Society Approvals</h2>
        <p class="section-subtitle">
          Type approval documentation available from all major classification societies.
          Contact us to confirm approval status for your specific project.
        </p>
        <CertLogos size="lg" showLabel={true} />
      </div>
    </section>

    <!-- Downloads -->
    {downloads.length > 0 && (
      <section class="product-downloads section" id="downloads">
        <div class="container container-narrow">
          <h2 class="section-title">Downloads & Documentation</h2>
          <ul class="downloads-list">
            {downloads.map(dl => (
              <li class="download-item">
                <div class="download-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
                </div>
                <div class="download-info">
                  <span class="download-label">{dl.label}</span>
                  {dl.gated && <span class="download-gated-badge">Requires registration</span>}
                </div>
                {dl.file ? (
                  dl.gated ? (
                    <a href="/contact/?download=1" class="btn btn-ghost download-btn">
                      Request Access
                    </a>
                  ) : (
                    <a href={dl.file} download class="btn btn-ghost download-btn">
                      Download
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </a>
                  )
                ) : (
                  <a href="/contact/" class="btn btn-ghost download-btn">
                    Request
                  </a>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- FAQ -->
    {faq.length > 0 && (
      <FAQAccordion items={faq} title={`${title} — FAQ`} />
    )}

    <!-- Related Products -->
    {relatedEntries.length > 0 && (
      <section class="related-products section" id="related">
        <div class="container">
          <h2 class="section-title">Related Products</h2>
          <div class="related-grid">
            {relatedEntries.map(entry => (
              <ProductCard
                title={entry.data.title}
                slug={entry.slug}
                description={entry.data.description}
                image={entry.data.heroImage}
                swlRange={entry.data.swlRange}
                certifications={entry.data.certifications}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA Block -->
    <CTABlock
      title={`Ready to Specify ${title}?`}
      subtitle="Provide your vessel type, required SWL, and classification society — we'll respond within 24 hours with a tailored technical proposal."
      buttonText="Get a Quote"
      buttonHref="/contact/"
      variant="dark"
    />
  </div>
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────── */
  .product-hero {
    background: var(--sj-dark);
    color: var(--sj-white);
    padding: var(--space-3xl) 0 var(--space-2xl);
  }
  .product-hero-title {
    color: var(--sj-white);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }
  .product-hero-desc {
    color: rgba(255,255,255,0.8);
    font-size: var(--text-lg);
    max-width: 640px;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }
  .product-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .meta-badge {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .meta-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
  }
  .meta-badge-swl .meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--sj-accent);
  }

  /* ── Type + Cert Pills ──────────────────────────── */
  .product-type-pills,
  .product-cert-pills {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .pills-label {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    white-space: nowrap;
  }
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .pill {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.03em;
    background: rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.2);
  }
  .pill-cert {
    background: rgba(232,121,43,0.2);
    color: #f5a96a;
    border-color: rgba(232,121,43,0.4);
  }

  /* ── Overview Two-Column ────────────────────────── */
  .product-overview-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 900px) {
    .product-overview-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Gallery */
  .gallery-main {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--sj-light);
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .gallery-placeholder {
    aspect-ratio: 4/3;
    background: var(--sj-light);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--sj-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    color: var(--sj-steel);
    font-size: var(--text-sm);
  }
  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }
  .gallery-thumb {
    aspect-ratio: 4/3;
    background: var(--sj-light);
    border-radius: var(--radius);
    border: 1px solid var(--sj-border);
  }
  .gallery-thumbs-placeholder .gallery-thumb {
    opacity: 0.4;
  }
  .gallery-thumb-btn {
    aspect-ratio: 4/3;
    border-radius: var(--radius);
    border: 2px solid var(--sj-border);
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: var(--sj-light);
    transition: border-color 0.2s;
  }
  .gallery-thumb-btn:hover,
  .gallery-thumb-btn.active {
    border-color: var(--sj-accent);
  }
  .gallery-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Sidebar */
  .product-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: sticky;
    top: var(--space-xl);
  }
  .quick-specs-title {
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sj-steel);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--sj-border);
  }
  .quick-specs-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
    font-size: var(--text-sm);
  }
  .quick-specs-list dt {
    color: var(--sj-steel);
    font-weight: 500;
    white-space: nowrap;
  }
  .quick-specs-list dd {
    color: var(--sj-primary);
    font-weight: 600;
    font-family: var(--font-mono);
    margin: 0;
  }
  .card-accent {
    border-top: 3px solid var(--sj-accent);
  }
  .card-accent h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }
  .card-accent p {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    margin-bottom: var(--space-lg);
  }
  .sidebar-cta-btn {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-sm);
  }
  .sidebar-cta-btn-secondary {
    width: 100%;
    justify-content: center;
    font-size: var(--text-sm);
  }
  .last-updated {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-xs);
    color: var(--sj-steel);
    margin-top: 0;
  }

  /* ── Spec Table Section ─────────────────────────── */
  .spec-note {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--sj-steel);
    font-style: italic;
  }

  /* ── Types Grid ─────────────────────────────────── */
  .types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }
  .type-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-xl);
    gap: var(--space-md);
  }
  .type-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(27,58,92,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sj-primary);
  }
  .type-name {
    font-size: var(--text-base);
    margin: 0;
  }

  /* ── Certifications ─────────────────────────────── */
  .section-light {
    background: var(--sj-light);
  }
  .section-subtitle {
    text-align: center;
    max-width: 560px;
    margin: 0 auto var(--space-2xl);
    color: var(--sj-steel);
  }

  /* ── Downloads ──────────────────────────────────── */
  .downloads-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }
  .download-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition);
  }
  .download-item:hover {
    border-color: var(--sj-primary);
  }
  .download-icon {
    flex-shrink: 0;
    color: var(--sj-primary);
  }
  .download-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .download-label {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--sj-primary);
  }
  .download-gated-badge {
    font-size: var(--text-xs);
    color: var(--sj-steel);
  }
  .download-btn {
    flex-shrink: 0;
    font-size: var(--text-sm);
    padding: 0.4rem 1rem;
  }

  /* ── Related Products ───────────────────────────── */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  /* ── MDX Body Prose ────────────────────────────── */
  .product-body :global(.prose h2) {
    font-size: var(--text-2xl);
    color: var(--sj-primary);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }
  .product-body :global(.prose h3) {
    font-size: var(--text-xl);
    color: var(--sj-primary);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }
  .product-body :global(.prose p) {
    color: var(--sj-steel);
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }
  .product-body :global(.prose ul),
  .product-body :global(.prose ol) {
    padding-left: 1.5rem;
    color: var(--sj-steel);
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }
  .product-body :global(.prose strong) {
    color: var(--sj-primary);
    font-weight: 600;
  }

  /* ── Shared ─────────────────────────────────────── */
  .section-title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const mainImg = document.getElementById('gallery-main-img') as HTMLImageElement | null;
    if (!mainImg) return;
    document.querySelectorAll('.gallery-thumb-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.src;
        if (src && mainImg) {
          mainImg.src = src;
          document.querySelectorAll('.gallery-thumb-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        }
      });
    });
  });
</script>
