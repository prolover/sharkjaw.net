---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import { company } from '../../data/company';

const datasheets = [
  {
    title: 'Shark Jaw Datasheet',
    description: 'Technical specifications, SWL ratings, dimensional drawings, and hydraulic parameters for the SharkJaw SJ-series.',
    fileNote: 'PDF — Coming Soon',
    available: false,
  },
  {
    title: 'Towing Pin Datasheet',
    description: 'Specifications, SWL ratings, pin diameter range, and installation notes for the SharkJaw TP-series towing pins.',
    fileNote: 'PDF — Coming Soon',
    available: false,
  },
  {
    title: 'Combination Unit Datasheet',
    description: 'Technical overview of the combined shark jaw + towing pin configurations for vessels requiring both systems.',
    fileNote: 'PDF — Coming Soon',
    available: false,
  },
  {
    title: 'HPU Specifications',
    description: 'Hydraulic Power Unit specifications, flow rates, pressure settings, and motor options for deck-mounted installations.',
    fileNote: 'PDF — Coming Soon',
    available: false,
  },
];
---

<BaseLayout
  title="Technical Downloads"
  description="Download product datasheets, catalogs, and technical documentation for SharkJaw shark jaw and towing pin systems."
>

  <!-- ══════════════════════════════════════════
       BREADCRUMB
  ══════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumb items={[{ label: 'Downloads' }]} />
  </div>

  <!-- ══════════════════════════════════════════
       1. PAGE HEADER
  ══════════════════════════════════════════ -->
  <section class="page-header">
    <div class="container">
      <p class="page-eyebrow">Resources</p>
      <h1>Technical Downloads</h1>
      <p class="page-subtitle">
        Product datasheets, technical specifications, and documentation for SharkJaw
        shark jaw and towing pin systems. GA drawings and project-specific documents
        are available on request.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       2. PRODUCT DATASHEETS
  ══════════════════════════════════════════ -->
  <section class="section section-white">
    <div class="container">
      <h2>Product Datasheets</h2>
      <p class="section-desc">
        Technical datasheets provide rated SWL, hydraulic parameters, dimensional drawings,
        material grades, and classification society compatibility for each product line.
      </p>
      <div class="download-grid">
        {datasheets.map((item) => (
          <div class:list={['download-card', item.available ? 'available' : 'coming-soon']}>
            <div class="download-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="download-info">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
              <span class="file-note">{item.fileNote}</span>
            </div>
            <div class="download-action">
              {item.available ? (
                <a href="#" class="btn btn-primary btn-sm">
                  Download
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                </a>
              ) : (
                <span class="badge-coming-soon">Coming Soon</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       3. PRODUCT CATALOG
  ══════════════════════════════════════════ -->
  <section class="section section-light">
    <div class="container">
      <div class="catalog-block">
        <div class="catalog-icon" aria-hidden="true">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <div class="catalog-info">
          <h2>Product Catalog</h2>
          <p>
            The comprehensive SharkJaw product catalog covers our full range of shark jaw
            and towing pin systems, SWL ratings from {company.stats.swlRange},
            available configurations, classification society options, and standard lead times.
          </p>
          <span class="badge-coming-soon">PDF — Coming Soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       4. GA DRAWINGS
  ══════════════════════════════════════════ -->
  <section class="section section-white">
    <div class="container container-narrow">
      <div class="ga-block">
        <div class="ga-header">
          <div class="ga-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
              <line x1="9" y1="9" x2="9" y2="21"/>
              <line x1="15" y1="9" x2="15" y2="21"/>
            </svg>
          </div>
          <h2>General Arrangement (GA) Drawings</h2>
        </div>
        <p>
          GA drawings are project-specific documents. Dimensions, mounting configurations,
          hydraulic connection points, and interface details vary by vessel type and SWL requirement.
        </p>
        <p>
          GA drawings are generated for each confirmed order and are provided to your
          engineering team for review and approval before production commences.
        </p>
        <div class="ga-cta">
          <a href="/contact/" class="btn btn-primary">
            Request via Inquiry Form
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <p class="ga-note">
            Include your vessel type, required SWL, and classification society.
            We respond within {company.tradeTerms.responseTime}.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       5. REQUEST NOTE
  ══════════════════════════════════════════ -->
  <section class="section section-light">
    <div class="container container-narrow">
      <div class="note-block">
        <div class="note-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <p>
          GA drawings and detailed technical specifications are available upon request.
          Contact us with your project requirements — vessel type, SWL rating, classification
          society, and any deck interface constraints — and we will provide the appropriate
          documentation for your engineering review.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       6. CTA
  ══════════════════════════════════════════ -->
  <CTABlock
    title="Need Project-Specific Documentation?"
    subtitle="Submit your inquiry and we'll prepare a full technical proposal including drawings and specifications."
  />

</BaseLayout>

<style>
  /* ---- Page Header ---- */
  .page-header {
    background: var(--sj-dark);
    color: var(--sj-white);
    padding: var(--space-4xl) 0 var(--space-3xl);
  }
  .page-eyebrow {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sj-accent);
    margin-bottom: var(--space-md);
  }
  .page-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1.1;
    color: var(--sj-white);
    margin-bottom: var(--space-lg);
  }
  .page-subtitle {
    font-size: var(--text-xl);
    line-height: 1.65;
    color: rgba(255,255,255,0.8);
    max-width: 680px;
  }

  /* ---- Sections ---- */
  .section { padding: var(--space-4xl) 0; }
  .section-white { background: var(--sj-white); }
  .section-light  { background: var(--sj-light); }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }
  .container-narrow { max-width: var(--container-narrow); }

  .section-desc {
    color: var(--sj-steel);
    font-size: var(--text-base);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  /* ---- Download Grid ---- */
  .download-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .download-card {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    background: var(--sj-light);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: box-shadow var(--transition);
  }
  .download-card:hover {
    box-shadow: var(--shadow-sm);
  }
  .download-icon {
    flex-shrink: 0;
    color: var(--sj-steel);
    width: 48px;
    height: 48px;
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .download-info {
    flex: 1;
  }
  .download-info h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--sj-primary);
    margin-bottom: var(--space-xs);
  }
  .download-info p {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    line-height: 1.6;
    margin-bottom: var(--space-sm);
  }
  .file-note {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--sj-steel);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .download-action {
    flex-shrink: 0;
  }

  /* ---- Badges ---- */
  .badge-coming-soon {
    display: inline-block;
    background: var(--sj-light);
    border: 1px solid var(--sj-border);
    color: var(--sj-steel);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
  }

  /* ---- Catalog Block ---- */
  .catalog-block {
    display: flex;
    gap: var(--space-2xl);
    align-items: flex-start;
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    max-width: 820px;
  }
  .catalog-icon {
    flex-shrink: 0;
    color: var(--sj-accent);
    margin-top: var(--space-xs);
  }
  .catalog-info h2 {
    margin-bottom: var(--space-md);
  }
  .catalog-info p {
    color: var(--sj-steel);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  /* ---- GA Drawings ---- */
  .ga-block {
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
  }
  .ga-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .ga-icon {
    flex-shrink: 0;
    color: var(--sj-accent);
  }
  .ga-header h2 {
    margin: 0;
  }
  .ga-block p {
    color: var(--sj-steel);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
  .ga-cta {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--sj-border);
  }
  .ga-note {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    margin: 0;
    line-height: 1.5;
  }

  /* ---- Note Block ---- */
  .note-block {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-left: 3px solid var(--sj-accent);
    border-radius: var(--radius);
    padding: var(--space-xl);
  }
  .note-icon {
    flex-shrink: 0;
    color: var(--sj-accent);
    margin-top: 2px;
  }
  .note-block p {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    line-height: 1.7;
    margin: 0;
  }

  /* ---- Button ---- */
  .btn-sm {
    padding: 0.5rem 1.25rem;
    font-size: var(--text-sm);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .download-card {
      flex-wrap: wrap;
    }
    .download-action {
      width: 100%;
    }
    .catalog-block {
      flex-direction: column;
    }
    .ga-cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
  @media (max-width: 600px) {
    .page-header h1 { font-size: var(--text-3xl); }
  }
</style>
