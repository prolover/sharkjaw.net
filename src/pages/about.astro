---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CertLogos from '../components/CertLogos.astro';
import CTABlock from '../components/CTABlock.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { company } from '../data/company';
---

<BaseLayout
  title="About SharkJaw"
  description="SharkJaw is a Hong Kong-based specialist in shark jaw and towing pin systems for tugboats and AHTS vessels. 15+ years of maritime expertise. All major class societies."
  type="AboutPage"
>
  <SchemaOrg
    type="AboutPage"
    title="About SharkJaw"
    description="SharkJaw is a Hong Kong-based specialist in shark jaw and towing pin systems for tugboats and AHTS vessels. 15+ years of maritime expertise. All major class societies."
    author={true}
  />

  <!-- ══════════════════════════════════════════
       BREADCRUMB
  ══════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumb items={[{ label: 'About' }]} />
  </div>

  <!-- ══════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════ -->
  <section class="about-hero">
    <div class="about-hero-overlay"></div>
    <div class="container about-hero-inner">
      <p class="about-eyebrow">Marine Towing Equipment Specialists</p>
      <h1>Built for the Toughest Jobs at Sea</h1>
      <p class="about-hero-subtitle">
        SharkJaw is your specialist partner for shark jaw and towing pin systems —
        the critical deck equipment that keeps towing operations safe and efficient.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       2. COMPANY STORY
  ══════════════════════════════════════════ -->
  <section class="section section-white">
    <div class="container container-narrow">
      <h2>Who We Are</h2>
      <div class="story-body">
        <p>
          <strong>{company.legalName}</strong> is focused exclusively on shark jaw
          and towing pin systems — the two pieces of deck equipment that define safe
          towing operations for tugboats, AHTS vessels, and offshore support fleets.
        </p>
        <p>
          With {company.stats.yearsExperience} years of maritime equipment expertise,
          we are not a general trading company offering thousands of catalogue items.
          We are a towing equipment specialist. That narrow focus means deeper technical
          knowledge, tighter supplier relationships, and faster responses on every
          inquiry we receive.
        </p>
        <p>
          We are transparent about what we are: a Hong Kong trading company partnered
          with proven, class-approved manufacturers in China. We select, quality-control,
          and deliver — you get classification-ready equipment with Hong Kong service
          standards.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       3. FOUR PILLARS
  ══════════════════════════════════════════ -->
  <section class="section section-light">
    <div class="container">
      <h2 class="section-heading-center">Why SharkJaw</h2>
      <div class="pillars-grid">

        <div class="pillar-card">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Towing Equipment Specialists</h3>
          <p>
            Only shark jaw and towing pin systems. No product sprawl. Deep technical
            knowledge on a narrow product set means better answers, faster.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <h3>Classification-Ready</h3>
          <p>
            All {company.stats.classificationSocieties} major classification societies.
            We handle the certification process and provide complete documentation with every order.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
          </div>
          <h3>Partnered Manufacturing</h3>
          <p>
            Heavy machining, hydraulic testing, factory QC. We own the quality
            assurance process through our manufacturing partnerships — not just
            pass-through trading.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <h3>Global Delivery, Hong Kong Efficiency</h3>
          <p>
            T/T, L/C, D/P. FOB/CIF/CFR. USD/EUR/CNY. Standard trade terms,
            transparent logistics, and a single point of contact in Hong Kong.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       4. MEET THE TEAM
  ══════════════════════════════════════════ -->
  <section class="section section-white">
    <div class="container">
      <h2 class="section-heading-center">The Person Behind SharkJaw</h2>
      <p class="section-subheading">E-E-A-T Rule #3 — Person credibility anchors every claim on this site.</p>

      <div class="team-card">
        <div class="team-photo-wrap">
          <div class="team-photo-placeholder" aria-label="Photo of David Zhu">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
        </div>
        <div class="team-info">
          <h3 class="team-name">{company.founder.displayName}</h3>
          <p class="team-aka">({company.founder.name})</p>
          <p class="team-title">{company.founder.title}</p>
          <p class="team-bio">
            {company.stats.yearsExperience} years in marine equipment sourcing and technical sales.
            Specializing in deck machinery, towing systems, and classification society certification
            for offshore and tugboat operators worldwide. Has worked directly with shipyards,
            ship managers, and procurement teams across Asia, the Middle East, and Europe on
            towing equipment specifications, FAT supervision, and delivery logistics.
          </p>
          <a
            href={company.founder.linkedin}
            class="team-linkedin"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
            Connect on LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       5. MANUFACTURING
  ══════════════════════════════════════════ -->
  <section class="section section-light">
    <div class="container">
      <div class="mfg-layout">
        <div class="mfg-copy">
          <h2>Our Manufacturing Partners</h2>
          <p>
            We work with established heavy machining and hydraulics fabricators in China
            who have a track record with classification society witnessing. Our role is
            supplier selection, QC oversight, and documentation management — so your
            procurement team receives ready-to-certify equipment.
          </p>
          <p>
            Independent third-party inspection (SGS, Bureau Veritas, etc.) is available
            on request for any order.
          </p>
        </div>
        <ul class="mfg-list">
          <li>
            <span class="mfg-check" aria-hidden="true">✓</span>
            CNC machining of jaw bodies and towing pins
          </li>
          <li>
            <span class="mfg-check" aria-hidden="true">✓</span>
            Hydraulic cylinder assembly and pressure testing
          </li>
          <li>
            <span class="mfg-check" aria-hidden="true">✓</span>
            Marine coating and surface treatment
          </li>
          <li>
            <span class="mfg-check" aria-hidden="true">✓</span>
            Factory Acceptance Testing (FAT) available
          </li>
          <li>
            <span class="mfg-check" aria-hidden="true">✓</span>
            Independent third-party inspection on request
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       6. CERTIFICATIONS
  ══════════════════════════════════════════ -->
  <section class="section section-white cert-section">
    <div class="container">
      <h2 class="section-heading-center">Classification Society Coverage</h2>
      <CertLogos size="lg" showLabel={false} />
      <p class="cert-text">
        We support type approval from all major classification societies.
        Certification documentation is provided with every order.
      </p>
      <p class="cert-link-wrap">
        <a href="/certifications/" class="cert-link">
          View certifications &amp; approvals
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       7. INDUSTRIES SERVED
  ══════════════════════════════════════════ -->
  <section class="section section-light">
    <div class="container">
      <h2 class="section-heading-center">Industries Served</h2>
      <div class="industries-grid">
        {[
          'Harbour Tugs',
          'Ocean-Going Tugs',
          'AHTS Vessels',
          'Platform Supply Vessels',
          'Offshore Support Vessels',
          'Salvage & Rescue',
          'Cable-Laying Vessels',
          'Naval Vessels',
        ].map(industry => (
          <div class="industry-item">
            <span class="industry-dot" aria-hidden="true"></span>
            {industry}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       8. HOW WE WORK
  ══════════════════════════════════════════ -->
  <section class="section section-dark">
    <div class="container">
      <h2 class="section-heading-center section-heading-white">How We Work</h2>
      <div class="process-steps">

        <div class="process-step">
          <div class="step-num" aria-hidden="true">01</div>
          <div class="step-body">
            <h3>Specification Review</h3>
            <p class="step-timeline">Day 1–2</p>
            <p>
              We review your vessel type, SWL requirement, chain/rope dimensions,
              and classification society. Ask questions. Flag conflicts. Confirm scope.
            </p>
          </div>
        </div>

        <div class="process-step">
          <div class="step-num" aria-hidden="true">02</div>
          <div class="step-body">
            <h3>Technical Proposal</h3>
            <p class="step-timeline">Day 3–7</p>
            <p>
              Full technical datasheet, hydraulic schematic, dimensional drawing,
              and commercial quotation. Clear pricing. No hidden fees.
            </p>
          </div>
        </div>

        <div class="process-step">
          <div class="step-num" aria-hidden="true">03</div>
          <div class="step-body">
            <h3>Manufacturing &amp; QC</h3>
            <p class="step-timeline">Week 2–12</p>
            <p>
              Production, classification society witnessing, pressure testing, FAT
              (if required), and final inspection before shipment.
            </p>
          </div>
        </div>

        <div class="process-step">
          <div class="step-num" aria-hidden="true">04</div>
          <div class="step-body">
            <h3>Delivery &amp; Support</h3>
            <p class="step-timeline">Ongoing</p>
            <p>
              FOB/CIF/CFR from Hong Kong or direct from factory. Complete shipping
              documentation. Post-delivery technical support available.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       9. CTA
  ══════════════════════════════════════════ -->
  <CTABlock
    title="Ready to Discuss Your Project?"
    subtitle="Tell us your vessel type, required SWL, and classification society."
  />

</BaseLayout>

<style>
  /* ---- Hero ---- */
  .about-hero {
    position: relative;
    background: var(--sj-dark);
    color: var(--sj-white);
    padding: var(--space-4xl) 0 var(--space-3xl);
    overflow: hidden;
  }
  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(27,58,92,0.5) 0%, rgba(13,27,42,0.8) 100%);
    pointer-events: none;
  }
  .about-hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--container-narrow);
  }
  .about-eyebrow {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sj-accent);
    margin-bottom: var(--space-md);
  }
  .about-hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: 1.1;
    color: var(--sj-white);
    margin-bottom: var(--space-lg);
  }
  .about-hero-subtitle {
    font-size: var(--text-xl);
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    max-width: 680px;
  }

  /* ---- Sections ---- */
  .section {
    padding: var(--space-4xl) 0;
  }
  .section-white { background: var(--sj-white); }
  .section-light { background: var(--sj-light); }
  .section-dark {
    background: var(--sj-dark);
    color: var(--sj-white);
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }
  .container-narrow {
    max-width: var(--container-narrow);
  }

  .section-heading-center {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }
  .section-heading-white {
    color: var(--sj-white);
  }
  .section-subheading {
    text-align: center;
    color: var(--sj-steel);
    font-size: var(--text-sm);
    margin-top: calc(-1 * var(--space-xl));
    margin-bottom: var(--space-2xl);
  }

  /* ---- Story ---- */
  .story-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .story-body p {
    font-size: var(--text-lg);
    line-height: 1.75;
    color: var(--sj-dark);
  }

  /* ---- Pillars ---- */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }
  .pillar-card {
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: box-shadow var(--transition);
  }
  .pillar-card:hover {
    box-shadow: var(--shadow-md);
  }
  .pillar-icon {
    color: var(--sj-accent);
    margin-bottom: var(--space-md);
  }
  .pillar-card h3 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--sj-primary);
    margin-bottom: var(--space-sm);
  }
  .pillar-card p {
    color: var(--sj-steel);
    line-height: 1.65;
  }

  /* ---- Team ---- */
  .team-card {
    display: flex;
    gap: var(--space-2xl);
    align-items: flex-start;
    background: var(--sj-light);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    max-width: 820px;
    margin: 0 auto;
  }
  .team-photo-wrap {
    flex-shrink: 0;
  }
  .team-photo-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--sj-border);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--sj-white);
    box-shadow: var(--shadow-sm);
  }
  .team-name {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--sj-primary);
    margin-bottom: 0;
  }
  .team-aka {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    margin-bottom: var(--space-xs);
  }
  .team-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--sj-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-md);
  }
  .team-bio {
    color: var(--sj-dark);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }
  .team-linkedin {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: #0A66C2;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: opacity var(--transition);
  }
  .team-linkedin:hover { opacity: 0.75; }

  /* ---- Manufacturing ---- */
  .mfg-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }
  .mfg-copy h2 {
    margin-bottom: var(--space-lg);
  }
  .mfg-copy p {
    color: var(--sj-dark);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
  .mfg-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-sm);
  }
  .mfg-list li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-lg);
    color: var(--sj-dark);
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius);
    padding: var(--space-md) var(--space-lg);
  }
  .mfg-check {
    color: var(--sj-success);
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  /* ---- Certifications ---- */
  .cert-section .section-heading-center {
    margin-bottom: var(--space-xl);
  }
  .cert-text {
    text-align: center;
    color: var(--sj-steel);
    max-width: 560px;
    margin: var(--space-xl) auto var(--space-md);
  }
  .cert-link-wrap {
    text-align: center;
  }
  .cert-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--sj-accent);
    font-weight: 600;
    text-decoration: none;
    transition: opacity var(--transition);
  }
  .cert-link:hover { opacity: 0.75; }

  /* ---- Industries ---- */
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }
  .industry-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--sj-white);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius);
    padding: var(--space-md) var(--space-lg);
    font-weight: 500;
    color: var(--sj-primary);
  }
  .industry-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sj-accent);
    flex-shrink: 0;
  }

  /* ---- Process Steps ---- */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    position: relative;
  }
  .process-step {
    position: relative;
  }
  .step-num {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: var(--sj-accent);
    line-height: 1;
    margin-bottom: var(--space-md);
  }
  .step-body h3 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--sj-white);
    margin-bottom: var(--space-xs);
  }
  .step-timeline {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--sj-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }
  .step-body p:last-child {
    color: rgba(255,255,255,0.7);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
    .mfg-layout {
      grid-template-columns: 1fr;
    }
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .about-hero {
      padding: var(--space-3xl) 0 var(--space-2xl);
    }
    .about-hero h1 {
      font-size: var(--text-3xl);
    }
    .team-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .team-linkedin {
      justify-content: center;
    }
    .industries-grid {
      grid-template-columns: 1fr 1fr;
    }
    .process-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
