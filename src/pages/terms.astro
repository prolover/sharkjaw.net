---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { company } from '../data/company';

const lastUpdated = '2026-03-30';
---

<BaseLayout
  title="Terms & Conditions"
  description="Terms and conditions for using the SharkJaw website and services."
  noIndex={true}
>

  <!-- ══════════════════════════════════════════
       BREADCRUMB
  ══════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumb items={[{ label: 'Terms & Conditions' }]} />
  </div>

  <!-- ══════════════════════════════════════════
       LEGAL PAGE CONTENT
  ══════════════════════════════════════════ -->
  <section class="legal-page">
    <div class="container container-narrow">

      <header class="legal-header">
        <h1>Terms &amp; Conditions</h1>
        <p class="last-updated">Last updated: {lastUpdated}</p>
        <p class="legal-intro">
          These Terms &amp; Conditions govern your use of the {company.name} website at{' '}
          <strong>{company.url}</strong> and any business conducted with{' '}
          {company.legalName} ("SharkJaw", "we", "us", or "our").
          By accessing this website or submitting an inquiry, you agree to these terms.
        </p>
      </header>

      <div class="legal-body">

        <section class="legal-section">
          <h2>1. Acceptance of Terms</h2>
          <p>
            By accessing and using this website, you accept and agree to be bound by these
            Terms &amp; Conditions. If you do not agree to these terms, please do not use this
            website or submit any inquiries.
          </p>
          <p>
            We reserve the right to modify these terms at any time. Changes take effect
            immediately upon posting. Your continued use of the website constitutes acceptance
            of any revised terms.
          </p>
        </section>

        <section class="legal-section">
          <h2>2. Use of Website</h2>
          <p>
            This website is provided for informational purposes to describe the products and
            services offered by {company.legalName}. You may use this website to:
          </p>
          <ul>
            <li>Learn about SharkJaw products and technical specifications</li>
            <li>Submit product inquiries and request quotations</li>
            <li>Download available technical documentation</li>
            <li>Contact our team for commercial or technical questions</li>
          </ul>
          <p>
            Product information, specifications, and pricing on this website are subject to
            change without notice. Technical data published here is provided as general guidance
            only. Project-specific parameters are confirmed in writing with each formal quotation.
          </p>
          <p>
            You agree not to use this website to transmit unsolicited commercial communications,
            attempt unauthorized access to our systems, or engage in any activity that may
            harm the website or its users.
          </p>
        </section>

        <section class="legal-section">
          <h2>3. Quotations &amp; Orders</h2>
          <p>
            All quotations issued by {company.legalName} are valid for{' '}
            <strong>30 days</strong> from the date of issue unless otherwise stated in the
            quotation document.
          </p>
          <p>
            Quotations are subject to final confirmation and are not binding until:
          </p>
          <ul>
            <li>A formal purchase order has been received from the buyer</li>
            <li>Order acknowledgment has been issued by {company.legalName}</li>
            <li>Any required advance payment has been received and cleared</li>
          </ul>
          <p>
            Product availability and lead times are indicative. Confirmed lead times are
            stated in the order acknowledgment. Delivery schedules are subject to classification
            society survey availability where applicable.
          </p>
        </section>

        <section class="legal-section">
          <h2>4. Intellectual Property</h2>
          <p>
            All content on this website — including text, product descriptions, technical
            documentation, graphics, and the SharkJaw name and logo — is the property of
            {company.legalName} or its content suppliers and is protected by applicable
            intellectual property laws.
          </p>
          <p>
            You may download and print content from this website for personal, non-commercial
            reference purposes only. You may not reproduce, republish, redistribute, or
            commercially exploit any content from this website without prior written permission.
          </p>
          <p>
            Technical drawings and project-specific documentation issued with quotations or
            orders remain the property of {company.legalName} and may not be shared with
            third parties without written consent.
          </p>
        </section>

        <section class="legal-section">
          <h2>5. Limitation of Liability</h2>
          <p>
            This website and its content are provided "as is" without warranty of any kind,
            express or implied. We make no representations as to the completeness, accuracy,
            or suitability of the information for any particular purpose.
          </p>
          <p>
            To the maximum extent permitted by applicable law, {company.legalName} shall not
            be liable for any indirect, incidental, consequential, or punitive damages arising
            from your use of this website or reliance on information contained herein.
          </p>
          <p>
            Our liability for any direct damages arising from a confirmed order shall not exceed
            the value of the specific order giving rise to the claim.
          </p>
        </section>

        <section class="legal-section">
          <h2>6. Governing Law</h2>
          <p>
            These Terms &amp; Conditions are governed by and construed in accordance with the
            laws of the State of <strong>Wyoming, USA</strong>. Any disputes arising out of
            or relating to these terms or your use of this website shall be subject to the
            exclusive jurisdiction of the courts of Wyoming, USA.
          </p>
          <p>
            For international commercial contracts entered into as a result of inquiries on
            this website, the governing law and dispute resolution mechanism will be specified
            in the applicable contract or purchase order terms.
          </p>
        </section>

        <section class="legal-section">
          <h2>7. Contact</h2>
          <p>
            For questions about these Terms &amp; Conditions, or for any commercial or legal
            correspondence, please contact:
          </p>
          <address class="legal-address">
            <strong>{company.legalName}</strong><br />
            {company.address.full}<br />
            Email: <a href={`mailto:${company.email}`}>{company.email}</a>
          </address>
        </section>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .legal-page {
    background: var(--sj-white);
    padding: var(--space-4xl) 0 var(--space-5xl, var(--space-4xl));
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }
  .container-narrow {
    max-width: var(--container-narrow);
  }

  /* ---- Header ---- */
  .legal-header {
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--sj-border);
  }
  .legal-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--sj-primary);
    margin-bottom: var(--space-sm);
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--sj-steel);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-lg);
  }
  .legal-intro {
    font-size: var(--text-lg);
    color: var(--sj-steel);
    line-height: 1.7;
  }

  /* ---- Body ---- */
  .legal-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .legal-section h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--sj-primary);
    margin-bottom: var(--space-md);
  }
  .legal-section p {
    color: var(--sj-dark);
    line-height: 1.75;
    margin-bottom: var(--space-md);
  }
  .legal-section p:last-child {
    margin-bottom: 0;
  }
  .legal-section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
    padding: 0;
  }
  .legal-section ul li {
    display: flex;
    gap: var(--space-sm);
    color: var(--sj-dark);
    line-height: 1.65;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--sj-border);
    font-size: var(--text-sm);
  }
  .legal-section ul li:last-child {
    border-bottom: none;
  }
  .legal-section ul li::before {
    content: '–';
    color: var(--sj-accent);
    font-weight: 700;
    flex-shrink: 0;
  }
  .legal-section a {
    color: var(--sj-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .legal-section a:hover {
    opacity: 0.8;
  }

  /* ---- Address ---- */
  .legal-address {
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--sj-dark);
    line-height: 2;
    background: var(--sj-light);
    border: 1px solid var(--sj-border);
    border-radius: var(--radius);
    padding: var(--space-lg) var(--space-xl);
    display: block;
    margin-top: var(--space-md);
  }
  .legal-address a {
    color: var(--sj-accent);
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .legal-header h1 {
      font-size: var(--text-3xl);
    }
  }
</style>
