---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const breadcrumbItems = [{ label: 'Blog' }];
---

<BaseLayout
  title="Blog"
  description="Technical articles about shark jaw systems, towing pins, and marine deck equipment."
>
  <div class="blog-index">
    <!-- Breadcrumb -->
    <div class="container">
      <Breadcrumb items={breadcrumbItems} />
    </div>

    <!-- Page Header -->
    <header class="blog-index-header section-dark">
      <div class="container">
        <h1 class="blog-index-title">SharkJaw Blog</h1>
        <p class="blog-index-subtitle">
          Technical guides, selection advice, and industry insights for marine towing equipment.
        </p>
      </div>
    </header>

    <!-- Article Grid -->
    <section class="blog-listing section">
      <div class="container">
        {posts.length === 0 ? (
          <div class="blog-empty">
            <p>No articles published yet. Check back soon.</p>
          </div>
        ) : (
          <div class="blog-grid">
            {posts.map(post => {
              const dateFormatted = new Intl.DateTimeFormat('en-GB', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              }).format(post.data.publishDate);

              return (
                <article class="blog-card card">
                  {post.data.heroImage ? (
                    <div class="blog-card-image">
                      <img
                        src={post.data.heroImage}
                        alt={post.data.title}
                        class="blog-card-img"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="blog-card-image blog-card-image-placeholder">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="9" cy="9" r="2"/>
                        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
                      </svg>
                    </div>
                  )}

                  <div class="blog-card-body">
                    <div class="blog-card-meta">
                      {post.data.category && (
                        <span class="blog-card-category">{post.data.category}</span>
                      )}
                      <div class="blog-card-meta-right">
                        <time
                          datetime={post.data.publishDate.toISOString()}
                          class="blog-card-date"
                        >
                          {dateFormatted}
                        </time>
                        {post.data.readingTime && (
                          <>
                            <span class="meta-sep" aria-hidden="true">·</span>
                            <span class="blog-card-reading-time">
                              {post.data.readingTime} min read
                            </span>
                          </>
                        )}
                      </div>
                    </div>

                    <h2 class="blog-card-title">
                      <a href={`/blog/${post.id}/`} class="blog-card-link">
                        {post.data.title}
                      </a>
                    </h2>

                    <p class="blog-card-desc">{post.data.description}</p>

                    <a href={`/blog/${post.id}/`} class="blog-card-read-more" aria-label={`Read ${post.data.title}`}>
                      Read More
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M5 12h14"/>
                        <path d="m12 5 7 7-7 7"/>
                      </svg>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ── Header ──────────────────────────────────────── */
  .blog-index-header {
    background: var(--sj-dark);
    color: var(--sj-white);
    padding: var(--space-3xl) 0 var(--space-2xl);
  }
  .blog-index-title {
    color: var(--sj-white);
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-md);
  }
  .blog-index-subtitle {
    color: rgba(255,255,255,0.7);
    font-size: var(--text-lg);
    max-width: 600px;
    line-height: 1.7;
  }

  /* ── Grid ────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  /* ── Card ────────────────────────────────────────── */
  .blog-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    transition: box-shadow var(--transition), transform var(--transition);
  }
  .blog-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  /* Card image */
  .blog-card-image {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--sj-light);
    flex-shrink: 0;
  }
  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .blog-card-img {
    transform: scale(1.03);
  }
  .blog-card-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--sj-border);
    color: var(--sj-steel);
  }

  /* Card body */
  .blog-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Meta row */
  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .blog-card-category {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(232,121,43,0.12);
    color: var(--sj-accent);
    border: 1px solid rgba(232,121,43,0.3);
  }
  .blog-card-meta-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--text-xs);
    color: var(--sj-steel);
  }
  .meta-sep {
    color: var(--sj-border);
  }

  /* Title */
  .blog-card-title {
    font-size: var(--text-xl);
    line-height: 1.3;
    margin-bottom: var(--space-sm);
  }
  .blog-card-link {
    color: var(--sj-primary);
    text-decoration: none;
    transition: color var(--transition);
  }
  .blog-card-link:hover {
    color: var(--sj-accent);
  }

  /* Description */
  .blog-card-desc {
    font-size: var(--text-sm);
    color: var(--sj-steel);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    flex: 1;
  }

  /* Read more */
  .blog-card-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-sm);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--sj-accent);
    text-decoration: none;
    transition: gap var(--transition);
    align-self: flex-start;
  }
  .blog-card-read-more:hover {
    gap: 0.6rem;
  }

  /* Empty state */
  .blog-empty {
    text-align: center;
    padding: var(--space-3xl) 0;
    color: var(--sj-steel);
  }
</style>
