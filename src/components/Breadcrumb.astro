---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const fullItems = [{ label: 'Home', href: '/' }, ...items];

// Schema.org BreadcrumbList
const schemaItems = fullItems.map((item, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: item.label,
  ...(item.href ? { item: new URL(item.href, Astro.site).href } : {}),
}));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};
---

<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {fullItems.map((item, i) => (
      <li>
        {i > 0 && <span class="breadcrumb-sep">/</span>}
        {item.href && i < fullItems.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current={i === fullItems.length - 1 ? 'page' : undefined}>{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .breadcrumb {
    padding: var(--space-md) 0;
    font-size: var(--text-xs);
    color: var(--sj-steel);
  }
  .breadcrumb ol {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
  }
  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .breadcrumb a {
    color: var(--sj-steel);
    text-decoration: none;
    transition: color var(--transition);
  }
  .breadcrumb a:hover {
    color: var(--sj-accent);
  }
  .breadcrumb-sep {
    color: var(--sj-border);
  }
  [aria-current="page"] {
    color: var(--sj-primary);
    font-weight: 500;
  }
</style>
