---
import { company } from '../data/company';
import { footerNav } from '../data/navigation';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <span class="footer-logo">SHARK<strong>JAW</strong></span>
        <p class="footer-tagline">
          Shark Jaw & Towing Pin systems for tugboats and AHTS vessels.
          {company.stats.swlRange} SWL. All major class societies.
        </p>
        <div class="footer-contact">
          <a href={`mailto:${company.email}`}>{company.email}</a>
          <a href={`tel:${company.phone}`}>{company.phone}</a>
          <span>{company.address.full}</span>
        </div>
      </div>

      <!-- Products -->
      <div class="footer-col">
        <h4>Products</h4>
        <ul>
          {footerNav.products.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          {footerNav.company.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
          {footerNav.resources.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Certifications -->
      <div class="footer-col">
        <h4>Certifications</h4>
        <div class="footer-certs">
          {company.certifications.map(cert => (
            <span class="footer-cert-badge">{cert}</span>
          ))}
        </div>
        <p class="footer-cert-note">
          Type approval available for all major classification societies.
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {company.legalName}. All rights reserved.</p>
      <div class="footer-legal">
        {footerNav.legal.map((link, i) => (
          <>
            {i > 0 && <span class="footer-sep">|</span>}
            <a href={link.href}>{link.label}</a>
          </>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--sj-dark);
    color: rgba(255,255,255,0.7);
    padding: var(--space-3xl) 0 var(--space-lg);
    font-size: var(--text-sm);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sj-white);
  }
  .footer-logo strong {
    color: var(--sj-accent);
    font-weight: 700;
  }
  .footer-tagline {
    margin-top: var(--space-md);
    line-height: 1.6;
  }
  .footer-contact {
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .footer-contact a {
    color: rgba(255,255,255,0.7);
    transition: color var(--transition);
  }
  .footer-contact a:hover {
    color: var(--sj-accent);
  }
  .footer-col h4 {
    color: var(--sj-white);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }
  .footer-col ul {
    list-style: none;
  }
  .footer-col li + li {
    margin-top: 0.4rem;
  }
  .footer-col a {
    color: rgba(255,255,255,0.7);
    transition: color var(--transition);
  }
  .footer-col a:hover {
    color: var(--sj-accent);
  }
  .footer-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .footer-cert-badge {
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 3px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.8);
  }
  .footer-cert-note {
    margin-top: var(--space-sm);
    font-size: var(--text-xs);
    line-height: 1.5;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
    font-size: var(--text-xs);
  }
  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-legal a {
    color: rgba(255,255,255,0.5);
  }
  .footer-legal a:hover {
    color: var(--sj-accent);
  }
  .footer-sep {
    color: rgba(255,255,255,0.2);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
