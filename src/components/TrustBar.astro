---
import { company } from '../data/company';
---

<div class="trust-bar">
  <div class="container trust-bar-inner">
    <div class="trust-bar-contact">
      <a href={`mailto:${company.email}`} class="trust-bar-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {company.email}
      </a>
      <a href={`tel:${company.phone}`} class="trust-bar-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {company.phone}
      </a>
    </div>
    <div class="trust-bar-certs">
      {company.certifications.map(cert => (
        <span class="trust-bar-cert">{cert}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--sj-dark);
    color: rgba(255,255,255,0.85);
    font-size: var(--text-xs);
    padding: 0.4rem 0;
  }
  .trust-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .trust-bar-contact {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .trust-bar-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: color var(--transition);
  }
  .trust-bar-item:hover {
    color: var(--sj-accent);
  }
  .trust-bar-item svg {
    flex-shrink: 0;
  }
  .trust-bar-certs {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .trust-bar-cert {
    padding: 0.1rem 0.4rem;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 2px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  @media (max-width: 640px) {
    .trust-bar-certs { display: none; }
  }
</style>
