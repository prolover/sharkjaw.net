---
/**
 * Head-side analytics + verification injection.
 * Companion <AnalyticsBody> renders the GTM <noscript> fallback right after <body>.
 *
 * GA4 Measurement ID is NOT injected here — it fires inside GTM via a
 * GA4 Configuration tag (configured in GTM workspace, not in code).
 */
import { analytics } from '../data/analytics';

const { gtmId, gscVerification, bingVerification } = analytics;
---

{gscVerification && <meta name="google-site-verification" content={gscVerification} />}
{bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

{gtmId && (
  <script is:inline define:vars={{ gtmId }}>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer',gtmId);
  </script>
)}
